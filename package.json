{
  "name": "fast58-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "bun run lint:js && bun run lint:native",
    "lint:fix": "bun run lint:fix:js && bun run lint:fix:native",
    "lint:js": "cd packages/fast58-js && bun run lint",
    "lint:fix:js": "cd packages/fast58-js && bun run lint:fix",
    "lint:native": "cd packages/fast58-native && bun run lint",
    "lint:fix:native": "cd packages/fast58-native && bun run lint:fix",
    "test": "bun run test:js && bun run test:native",
    "test:js": "cd packages/fast58-js && bun test",
    "test:native": "cd packages/fast58-native && bun test",
    "build:js": "cd packages/fast58-js && bun run build",
    "build:native": "cd packages/fast58-native && bun run build:native",
    "bench": "cd packages/fast58-native && bun run bench"
  },
  "devDependencies": {
    "oxlint": "^1.59.0"
  }
}
