{
  "name": "fast58-js",
  "version": "0.1.0",
  "description": "Fast Base58 encode/decode package with zero runtime dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "bun": "./dist/index.bun.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "bun run scripts/build.ts",
    "bundle": "bun run scripts/bundle.ts",
    "lint": "oxlint src scripts test bench",
    "lint:fix": "oxlint --fix src scripts test bench",
    "package:check": "bun run build && npm pack --dry-run",
    "prepack": "bun run build",
    "test": "bun test",
    "bench": "bun run scripts/bench.ts"
  },
  "devDependencies": {
    "@scure/base": "^2.0.0",
    "@types/bun": "^1.3.11",
    "base-x": "^5.0.1",
    "bs58": "^6.0.0",
    "oxlint": "^1.59.0"
  }
}
