{
  "name": "fast58-js",
  "version": "0.1.2",
  "description": "Fast Base58 encode/decode for Solana and other JavaScript apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "bun": "./dist/index.bun.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "logo.png",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/westsidelaboratories/fast58.git",
    "directory": "packages/fast58-js"
  },
  "bugs": {
    "url": "https://github.com/westsidelaboratories/fast58/issues"
  },
  "homepage": "https://github.com/westsidelaboratories/fast58#readme",
  "keywords": [
    "base58",
    "bs58",
    "fast",
    "solana",
    "typescript",
    "javascript",
    "bun",
    "encoding",
    "crypto"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "bun run scripts/build.ts",
    "bundle": "bun run scripts/bundle.ts",
    "lint": "oxlint src scripts test bench",
    "lint:fix": "oxlint --fix src scripts test bench",
    "package:check": "npm pack --dry-run --json",
    "prepack": "bun run build",
    "prepublishOnly": "bun test && bun run lint && bun run package:check",
    "release:check": "bun test && bun run lint && bun run package:check",
    "test": "bun test",
    "bench": "bun run scripts/bench.ts",
    "autoresearch": "bun run scripts/autoresearch.ts",
    "autoresearch:tiny": "bun run scripts/autoresearch-tiny.ts",
    "bench:rivals": "bun run build && bun run bench/quick-rivals.ts",
    "bench:all": "bun run build && bun run scripts/bench.ts"
  },
  "devDependencies": {
    "@scure/base": "^2.0.0",
    "@types/bun": "^1.3.11",
    "base-x": "^5.0.1",
    "base58": "^2.0.1",
    "base58-js": "^3.0.3",
    "bs58": "^6.0.0",
    "oxlint": "^1.59.0"
  }
}
