{
  "name": "fast58-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "lint": "oxlint benchmark.ts bench implementations index.ts test",
    "lint:fix": "oxlint --fix benchmark.ts bench implementations index.ts test",
    "test": "bun test",
    "bench": "bun run benchmark.ts",
    "bench:rust": "cargo run --release --example bench",
    "bench:rust-vs-js": "bun run bench/rust-vs-js.ts",
    "build:native": "napi build --platform --release"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1",
    "@types/bun": "^1.3.12",
    "oxlint": "^1.59.0"
  }
}
